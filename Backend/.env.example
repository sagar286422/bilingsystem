PORT=4000
HOST=0.0.0.0

BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
# Public URL where the app UI is served (local Next, or production Vercel).
# Production: https://YOUR-APP.vercel.app (match NEXT_PUBLIC_SITE_URL on Vercel)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated browser origins allowed by CORS. Must include your Vercel URL in production.
# CLIENT_ORIGIN=https://YOUR-APP.vercel.app,http://localhost:3000,http://localhost:5173
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173

# If true, public checkout API requires Authorization: Bearer pk_... (owned org must match page).
# Set Next.js NEXT_PUBLIC_BILLING_PUBLISHABLE_KEY to the same pk_ for hosted /pay pages.
# PUBLIC_CHECKOUT_REQUIRE_PUBLISHABLE_KEY=false

DB_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Platform Razorpay (your SaaS account; test vs live per deployment) ---
# Used when an org is on "platform" checkout — never put these in the database.
# No spaces around '='. The API also reads RAZORPAY_API_KEY / RAZORPAY_API_SECRET.
# PLATFORM_RAZORPAY_KEY_ID=rzp_test_xxxx
# PLATFORM_RAZORPAY_KEY_SECRET=xxxx
# RAZORPAY_API_KEY=rzp_test_xxxx
# RAZORPAY_API_SECRET=xxxx

# Optional: encrypt BYOK secrets at rest (generate 32-byte hex: openssl rand -hex 32)
# GATEWAY_CREDENTIALS_MASTER_KEY=
