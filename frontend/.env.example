# --- Local ---
BACKEND_URL=http://localhost:4000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Production (Vercel) ---
# In Vercel → Project → Settings → Environment Variables (Production + Preview):
#   BACKEND_URL=https://YOUR-SERVICE.onrender.com   (server rewrite target — required at build)
#   NEXT_PUBLIC_SITE_URL=https://YOUR-APP.vercel.app   (browser auth base + callbacks — required at build)
# If NEXT_PUBLIC_SITE_URL is missing, the deployed app now falls back to the current browser origin
# for auth; setting it explicitly is still recommended for previews/custom domains.
# No trailing slash on URLs. Root Directory for this monorepo: "frontend".
#
# On Render (API): set CLIENT_ORIGIN to your Vercel URL (and preview URL if needed):
#   CLIENT_ORIGIN=https://YOUR-APP.vercel.app
# And BETTER_AUTH_URL to the same Vercel URL so auth cookies + redirects match the UI origin.

# When Backend PUBLIC_CHECKOUT_REQUIRE_PUBLISHABLE_KEY=true, set full pk_test_... here
# NEXT_PUBLIC_BILLING_PUBLISHABLE_KEY=pk_test_...

NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=
